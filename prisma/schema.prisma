generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReactionType {
  like
  dislike
}

model User {
  id                        String   @id @default(cuid())
  email                     String   @unique
  username                  String   @unique
  password                  String
  displayName               String?
  bio                       String?
  avatarUrl                 String?
  bannerUrl                 String?
  themeColor                String?  @default("#f472b6")
  role                      String   @default("user")
  status                    String   @default("active")
  stripeCustomerId          String?

  selectedDecorationId      String?
  selectedDecorationScale   Float?   @default(165)
  selectedDecorationOffsetX Float?   @default(0)
  selectedDecorationOffsetY Float?   @default(0)

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @default(now()) @updatedAt

  selectedDecoration Decoration? @relation("SelectedDecoration", fields: [selectedDecorationId], references: [id], onDelete: SetNull)
  uploadedDecorations Decoration[] @relation("UploadedDecorations")

  sessions           Session[]
  links              Link[]
  reactionsGiven     Reaction[] @relation("ReactionsGiven")
  reactionsReceived  Reaction[] @relation("ReactionsReceived")
  badges             UserBadge[]
  adminLogs          AdminAuditLog[] @relation("AdminActorLogs")
  adminTargetLogs    AdminAuditLog[] @relation("AdminTargetLogs")
  reportsCreated     Report[] @relation("ReportsCreated")
  reportsAgainstUser Report[] @relation("ReportsAgainstUser")
  reportsReviewed    Report[] @relation("ReportsReviewed")
  profileViews       ProfileView[]

  @@index([username])
  @@index([status])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Link {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks  LinkClick[]
  reports Report[]

  @@index([userId, position])
  @@index([createdAt])
}

model LinkClick {
  id        String   @id @default(cuid())
  linkId    String
  createdAt DateTime @default(now())

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
}

model ProfileView {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Decoration {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  imageUrl        String
  previewUrl      String?
  posterUrl       String?
  mediaType       String   @default("image")
  isPublic        Boolean  @default(true)
  createdByUserId String?
  sortOrder       Int      @default(0)
  overlayScale    Float?   @default(165)
  overlayOffsetY  Float?   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  selectedByUsers User[] @relation("SelectedDecoration")
  createdBy       User?  @relation("UploadedDecorations", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([isPublic, sortOrder])
  @@index([createdByUserId])
}

model Reaction {
  id         String       @id @default(cuid())
  fromUserId String
  toUserId   String
  type       ReactionType
  createdAt  DateTime     @default(now())

  fromUser User @relation("ReactionsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReactionsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, createdAt])
  @@index([fromUserId])
}

model Badge {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  icon          String
  description   String?
  color         String?  @default("#f472b6")
  category      String?  @default("general")
  rarity        String?  @default("common")
  isHidden      Boolean  @default(false)
  isAutoAwarded Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  users UserBadge[]

  @@index([category])
  @@index([rarity])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId, createdAt])
  @@index([badgeId])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  targetUserId String?
  action       String
  reason       String?
  metadata     String?
  createdAt    DateTime @default(now())

  actorUser  User  @relation("AdminActorLogs", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser User? @relation("AdminTargetLogs", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action])
}

model Report {
  id              String   @id @default(cuid())
  createdByUserId String
  targetUserId    String?
  linkId          String?
  reason          String
  status          String   @default("open")
  reviewerUserId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  createdByUser User  @relation("ReportsCreated", fields: [createdByUserId], references: [id], onDelete: Cascade)
  targetUser    User? @relation("ReportsAgainstUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  reviewerUser  User? @relation("ReportsReviewed", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  link          Link? @relation(fields: [linkId], references: [id], onDelete: SetNull)

  @@index([createdByUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([reviewerUserId, createdAt])
  @@index([status])
}